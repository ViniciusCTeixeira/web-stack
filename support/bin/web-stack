Exemplos - Reiniciar:
  web-stack restart mysql             reinicia MySQL
  web-stack restart php84             reinicia PHP 8.4
  web-stack restart all               reinicia tudo

Exemplos - Manutenção:
  web-stack cleanup                   remove containers parados
  web-stack cleanup --volumes         remove containers e volumes
  web-stack cleanup --all             remove tudo
  web-stack backup                    cria backup (MySQL + Redis)
  web-stack restore backup_2024-04-05.tar.gz

Exemplos - Docker:
  web-stack docker up                 sobe containers
  web-stack docker down               desce containers
  web-stack docker build              faz build das imagens
  web-stack docker rebuild            rebuild completo
  web-stack docker list-versions      lista versões PHP
  sudo web-stack docker version add 82 8.2-fpm
  sudo web-stack docker version edit 84 8.4.2-fpm

Exemplos - Composer:
  web-stack composer 84 install       instala dependencies
  web-stack composer 84 require vendor/package
  web-stack composer 74 --version     verifica versão do Composer

Exemplos - VirtualHost:
  sudo web-stack vhost create crm.test crm 84
  sudo web-stack vhost create --ssl crm.test crm 84 public
  sudo web-stack vhost create --ssl --redirect-http crm.test crm 84 public
  sudo web-stack vhost edit --ssl crm.test crm 84
  sudo web-stack vhost remove crm.test

Exemplos - Localhost:
  sudo web-stack localhost version 83
  sudo web-stack localhost version 84

Dicas:
  web-stack -h                      mostra esta ajuda
  web-stack <categoria> -h          mostra ajuda da categoria
EOT
}

