#!/usr/bin/env bash
set -Eeuo pipefail

LIB_FILE="/usr/local/lib/web-stack.sh"

load_lib() {
  if [[ ! -f "${LIB_FILE}" ]]; then
    echo "Biblioteca nao encontrada: ${LIB_FILE}" >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  . "${LIB_FILE}"
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "Use sudo para este comando." >&2
    exit 1
  fi
}

error() {
  echo "❌ Erro: $*" >&2
  exit 1
}

warn() {
  echo "⚠️  Aviso: $*" >&2
}

success() {
  echo "✓ $*"
}

info() {
  echo "ℹ️  $*"
}

check_dependencies() {
  local missing=0

  if ! command -v docker >/dev/null 2>&1; then
    warn "Docker não está instalado"
    echo "   Execute: sudo apt-get install docker.io" >&2
    missing=1
  fi

  if command -v docker >/dev/null 2>&1 && ! docker ps >/dev/null 2>&1; then
    warn "Docker daemon não está rodando"
    echo "   Execute: sudo systemctl start docker" >&2
    missing=1
  fi

  if ! command -v docker-compose >/dev/null 2>&1 && ! docker compose version >/dev/null 2>&1; then
    warn "Docker Compose não encontrado"
    missing=1
  fi

  if [[ ! -f "/etc/web-stack.conf" ]]; then
    error "Arquivo de configuração não encontrado: /etc/web-stack.conf"
  fi

  if [[ $missing -eq 1 ]]; then
    error "Dependências não encontradas. Verifique os avisos acima."
  fi
}

main_help() {
  cat <<'EOT'
Uso:
  web-stack <categoria> <acao> [opcoes]

Categorias:
  docker       gerencia containers, compose, versoes PHP, MySQL e Redis
  vhost        cria, edita e remove VirtualHosts
  localhost    altera a versao PHP usada no localhost
  composer     executa Composer dentro do container PHP escolhido
  on           ativa recurso(s) (all, php, php74, php83, php84, mysql, redis)
  off          desativa recurso(s) (all, php, php74, php83, php84, mysql, redis)
  list         lista status detalhado de todos os recursos
  status       mostra status resumido (-v para verbose)
  logs         mostra logs de containers (mysql, php74-84, redis, all)
  shell        acesso bash/shell ao container
  restart      reinicia recurso(s)
  exec         executa comando no container
  stats        mostra uso de CPU/Memória
  cleanup      remove containers/volumes/images não utilizados
  backup       cria backup de MySQL e Redis
  restore      restaura backup

Exemplos - Controle de Recursos:
  web-stack on all                    ativa tudo
  web-stack off all                   desativa tudo
  web-stack on php84                  ativa só PHP 8.4
  web-stack on php83                  ativa só PHP 8.3
  web-stack off php74                 desativa só PHP 7.4
  web-stack on php                    ativa todas as versões PHP

Exemplos - Status e Logs:
  web-stack status                    mostra status resumido
  web-stack status -v                 mostra status detalhado
  web-stack list                      lista detalhada de recursos
  web-stack logs mysql                mostra logs do MySQL
  web-stack logs php84                mostra logs do PHP 8.4
  web-stack logs php84 -f             segue logs em tempo real
  web-stack logs all                  mostra logs de tudo
  web-stack stats                     mostra CPU/Memória dos containers

Exemplos - Acesso aos Containers:
  web-stack shell php84               entra no bash do PHP 8.4
  web-stack shell mysql               entra no mysql client
  web-stack shell redis               entra no redis-cli
  web-stack exec php84 php -v         executa comando PHP
  web-stack exec php84 composer install
